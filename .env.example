# ===== Swigto Frontend Environment Variables =====
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Backend API base URL (no trailing slash)
VITE_API_BASE_URL=https://api.foodrevolut.abhayvii.dev/api/v1

# WebSocket base URL (for live order tracking)
VITE_WS_BASE_URL=wss://api.foodrevolut.abhayvii.dev

# Razorpay Key ID (for payment integration)
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id
